<Grid
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
Width="1400"
Height="900"
Background="#F3F4F6">

	<Grid.Resources>

		<Style x:Key="PrimaryButton" TargetType="Button">
			<Setter Property="Width" Value="140"/>
			<Setter Property="Height" Value="36"/>
			<Setter Property="Background" Value="#4F6BED"/>
			<Setter Property="Foreground" Value="White"/>
		</Style>

		<Style x:Key="SidebarButton" TargetType="Button">
			<Setter Property="Width" Value="180"/>
			<Setter Property="Height" Value="40"/>
			<Setter Property="Background" Value="#374151"/>
			<Setter Property="Foreground" Value="White"/>
		</Style>

		<Style x:Key="Card" TargetType="Border">
			<Setter Property="Background" Value="White"/>
			<Setter Property="Padding" Value="15"/>
		</Style>

	</Grid.Resources>

	<Grid.RowDefinitions>
		<RowDefinition Height="Auto"/>
		<RowDefinition Height="*"/>
		<RowDefinition Height="Auto"/>
	</Grid.RowDefinitions>

	<Grid.ColumnDefinitions>
		<ColumnDefinition Width="240"/>
		<ColumnDefinition Width="*"/>
		<ColumnDefinition Width="320"/>
	</Grid.ColumnDefinitions>

	<!-- HEADER -->

	<Border Grid.Row="0" Grid.ColumnSpan="3" Background="#111827" Padding="15">

		<StackPanel Orientation="Horizontal">

			<TextBlock Text="Enterprise Management Dashboard"
           Foreground="White"
           Margin="0 0 20 0"/>

			<Button Content="Notifications" Style="{StaticResource PrimaryButton}"/>
			<Button Content="Profile" Style="{StaticResource PrimaryButton}" Margin="10 0"/>
			<Button Content="Logout" Style="{StaticResource PrimaryButton}" Margin="10 0"/>

		</StackPanel>

	</Border>

	<!-- SIDEBAR -->

	<Border Grid.Row="1" Grid.Column="0" Background="#1F2937" Padding="10">

		<StackPanel>

			<TextBlock Text="Navigation"
           Foreground="White"
           Margin="0 0 0 15"/>

			<Button Content="Dashboard" Style="{StaticResource SidebarButton}"/>
			<Button Content="Users" Style="{StaticResource SidebarButton}" Margin="0 5"/>
			<Button Content="Reports" Style="{StaticResource SidebarButton}" Margin="0 5"/>
			<Button Content="Analytics" Style="{StaticResource SidebarButton}" Margin="0 5"/>
			<Button Content="Settings" Style="{StaticResource SidebarButton}" Margin="0 5"/>
			<Button Content="Logs" Style="{StaticResource SidebarButton}" Margin="0 5"/>

		</StackPanel>

	</Border>

	<!-- MAIN CONTENT -->

	<Grid Grid.Row="1" Grid.Column="1">

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<!-- DASHBOARD CARDS -->

		<WrapPanel Grid.Row="0" Margin="10">

			<Border Style="{StaticResource Card}" Width="200" Margin="10">
				<StackPanel>
					<TextBlock Text="Users"/>
					<TextBlock Text="1,245"/>
				</StackPanel>
			</Border>

			<Border Style="{StaticResource Card}" Width="200" Margin="10">
				<StackPanel>
					<TextBlock Text="Revenue"/>
					<TextBlock Text="$25,000"/>
				</StackPanel>
			</Border>

			<Border Style="{StaticResource Card}" Width="200" Margin="10">
				<StackPanel>
					<TextBlock Text="Orders"/>
					<TextBlock Text="345"/>
				</StackPanel>
			</Border>

			<Border Style="{StaticResource Card}" Width="200" Margin="10">
				<StackPanel>
					<TextBlock Text="Errors"/>
					<TextBlock Text="12"/>
				</StackPanel>
			</Border>

		</WrapPanel>

		<!-- USER FORM -->

		<Border Grid.Row="1" Style="{StaticResource Card}" Margin="10">

			<StackPanel>

				<TextBlock Text="User Profile"/>

				<TextBox Width="300" Margin="0 5"/>
				<TextBox Width="300" Margin="0 5"/>

				<StackPanel Orientation="Horizontal" Margin="0 10">

					<CheckBox Content="Active"/>
					<RadioButton Content="Admin" Margin="15 0"/>

				</StackPanel>

				<Button Content="Save Changes"
        Style="{StaticResource PrimaryButton}"/>

			</StackPanel>

		</Border>

		<!-- TOOLBAR -->

		<Border Grid.Row="2" Style="{StaticResource Card}" Margin="10">

			<StackPanel>

				<TextBlock Text="Actions"/>

				<WrapPanel Margin="10">

					<Button Content="Add User" Style="{StaticResource PrimaryButton}"/>
					<Button Content="Edit User" Style="{StaticResource PrimaryButton}" Margin="10 0"/>
					<Button Content="Delete User" Style="{StaticResource PrimaryButton}" Margin="10 0"/>
					<Button Content="Export Data" Style="{StaticResource PrimaryButton}" Margin="10 0"/>

				</WrapPanel>

				<TextBlock Text="Filters"/>

				<ComboBox Width="200" Margin="0 10">
					<ComboBoxItem Content="All"/>
					<ComboBoxItem Content="Active"/>
					<ComboBoxItem Content="Inactive"/>
				</ComboBox>

				<ListBox Height="150" Width="300">

					<ListBoxItem Content="Option A"/>
					<ListBoxItem Content="Option B"/>
					<ListBoxItem Content="Option C"/>
					<ListBoxItem Content="Option D"/>
					<ListBoxItem Content="Option E"/>

				</ListBox>

				<Button Content="Apply Filters"
        Style="{StaticResource PrimaryButton}"
        Margin="0 10"/>

			</StackPanel>

		</Border>

	</Grid>

	<!-- RIGHT SIDEBAR -->

	<Border Grid.Row="1" Grid.Column="2" Style="{StaticResource Card}" Margin="10">

		<StackPanel>

			<TextBlock Text="Statistics"/>

			<Image Width="200" Height="120"/>

			<TextBlock Text="Online Users: 128"/>
			<TextBlock Text="Active Sessions: 42"/>
			<TextBlock Text="CPU Usage: 58%"/>
			<TextBlock Text="Memory Usage: 73%"/>

			<TextBlock Text="Recent Activity" Margin="0 20"/>

			<ListBox Height="200">

				<ListBoxItem Content="User John logged in"/>
				<ListBoxItem Content="Admin updated settings"/>
				<ListBoxItem Content="Backup completed"/>
				<ListBoxItem Content="New user registered"/>
				<ListBoxItem Content="System update installed"/>

			</ListBox>

		</StackPanel>

	</Border>

	<!-- FOOTER -->

	<Border Grid.Row="2"
        Grid.ColumnSpan="3"
        Background="#111827"
        Padding="10">

		<StackPanel Orientation="Horizontal">

			<Button Content="Help" Style="{StaticResource PrimaryButton}"/>
			<Button Content="About" Style="{StaticResource PrimaryButton}" Margin="10 0"/>
			<Button Content="Documentation" Style="{StaticResource PrimaryButton}" Margin="10 0"/>

		</StackPanel>

	</Border>

</Grid>