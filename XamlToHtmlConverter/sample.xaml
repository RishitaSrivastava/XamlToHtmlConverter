<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!-- This replaces the Window - Grid is a valid container for preview -->

	<!-- PASTE YOUR FULL BORDER CODE HERE -->
	<Border BorderThickness="2"
        BorderBrush="Gray"
        Padding="10"
        Width="1200"
        Height="800">

			<StackPanel>

				<TextBlock Text="Enterprise User Management"
						   FontSize="28"
						   FontWeight="Bold"
						   Foreground="DarkBlue"
						   Margin="10"/>

				<DockPanel Margin="10">

					<StackPanel DockPanel.Dock="Left"
								Width="200"
								Background="LightGray"
								Margin="5">

						<TextBlock Text="Navigation"
								   FontSize="18"
								   FontWeight="Bold"
								   Margin="5"/>

						<Button Content="Dashboard"
								Margin="5"
								Command="{Binding DashboardCommand}"/>

						<Button Content="Users"
								Margin="5"
								Command="{Binding UsersCommand}"/>

						<Button Content="Roles"
								Margin="5"
								Command="{Binding RolesCommand}"/>

						<Button Content="Permissions"
								Margin="5"
								Command="{Binding PermissionsCommand}"/>

						<Button Content="Audit Logs"
								Margin="5"
								Command="{Binding LogsCommand}"/>

					</StackPanel>

					<Grid Margin="10">

						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="*"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>

						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="2*"/>
							<ColumnDefinition Width="1*"/>
						</Grid.ColumnDefinitions>


						<!-- SEARCH PANEL -->

						<Border Grid.Row="0"
								Grid.ColumnSpan="2"
								BorderThickness="1"
								BorderBrush="LightGray"
								Padding="10"
								Margin="5">

							<StackPanel Orientation="Horizontal">

								<TextBlock Text="Search:"
										   VerticalAlignment="Center"
										   Margin="5"/>

								<TextBox Width="200"
										 Text="{Binding SearchText}"/>

								<Button Content="Search"
										Margin="10,0"
										Command="{Binding SearchCommand}"/>

								<Button Content="Reset"
										Command="{Binding ResetCommand}"/>

							</StackPanel>

						</Border>


						<!-- USER LIST -->

						<Border Grid.Row="1"
								Grid.RowSpan="2"
								Grid.Column="0"
								BorderThickness="1"
								BorderBrush="LightGray"
								Margin="5"
								Padding="5">

							<ListView ItemsSource="{Binding Users}"
									  Height="400">

								<ListView.ItemTemplate>

									<DataTemplate>

										<Border BorderThickness="1"
												BorderBrush="#DDD"
												Margin="2"
												Padding="6">

											<Grid>

												<Grid.ColumnDefinitions>
													<ColumnDefinition Width="2*"/>
													<ColumnDefinition Width="3*"/>
													<ColumnDefinition Width="2*"/>
													<ColumnDefinition Width="1*"/>
												</Grid.ColumnDefinitions>

												<TextBlock Grid.Column="0"
														   Text="{Binding Name}"
														   FontWeight="Bold"/>

												<TextBlock Grid.Column="1"
														   Text="{Binding Email}"/>

												<TextBlock Grid.Column="2"
														   Text="{Binding Role}"/>

												<StackPanel Grid.Column="3"
															Orientation="Horizontal">

													<Button Content="Edit"
															Command="{Binding EditCommand}"
															Width="60"/>

													<Button Content="Delete"
															Command="{Binding DeleteCommand}"
															Width="70"
															Margin="5,0"/>

												</StackPanel>

											</Grid>

										</Border>

									</DataTemplate>

								</ListView.ItemTemplate>

							</ListView>

						</Border>


						<!-- USER DETAILS -->

						<Border Grid.Row="1"
								Grid.Column="1"
								BorderThickness="1"
								BorderBrush="LightGray"
								Margin="5"
								Padding="10">

							<StackPanel>

								<TextBlock Text="User Details"
										   FontSize="18"
										   FontWeight="Bold"
										   Margin="5"/>

								<StackPanel Orientation="Horizontal" Margin="5">
									<TextBlock Text="Name:" Width="80"/>
									<TextBox Width="200"
											 Text="{Binding SelectedUser.Name}"/>
								</StackPanel>

								<StackPanel Orientation="Horizontal" Margin="5">
									<TextBlock Text="Email:" Width="80"/>
									<TextBox Width="200"
											 Text="{Binding SelectedUser.Email}"/>
								</StackPanel>

								<StackPanel Orientation="Horizontal" Margin="5">
									<TextBlock Text="Role:" Width="80"/>
									<TextBox Width="200"
											 Text="{Binding SelectedUser.Role}"/>
								</StackPanel>

								<CheckBox Content="Active"
										  IsChecked="{Binding SelectedUser.IsActive}"
										  Margin="5"/>

								<StackPanel Orientation="Horizontal" Margin="10">

									<Button Content="Save"
											Width="100"
											Command="{Binding SaveCommand}"/>

									<Button Content="Cancel"
											Width="100"
											Margin="10,0"
											Command="{Binding CancelCommand}"/>

								</StackPanel>

							</StackPanel>

						</Border>


						<!-- STATISTICS -->

						<Border Grid.Row="2"
								Grid.Column="1"
								BorderThickness="1"
								BorderBrush="LightGray"
								Margin="5"
								Padding="10">

							<StackPanel>

								<TextBlock Text="Statistics"
										   FontSize="18"
										   FontWeight="Bold"/>

								<TextBlock Text="Total Users:"/>
								<TextBlock Text="{Binding UserCount}"
										   FontSize="20"
										   FontWeight="Bold"/>

								<Button Content="Refresh Stats"
										Margin="10"
										Command="{Binding RefreshStatsCommand}"/>

							</StackPanel>

						</Border>


						<!-- FOOTER -->

						<StackPanel Grid.Row="3"
									Grid.ColumnSpan="2"
									Orientation="Horizontal"
									HorizontalAlignment="Center"
									Margin="10">

							<Button Content="Load More"
									Width="120"
									Command="{Binding LoadMoreCommand}"/>

							<TextBlock Text="Last Sync:"
									   Margin="20,0,5,0"/>

							<TextBlock Text="{Binding LastSyncTime}"/>

						</StackPanel>

					</Grid>

				</DockPanel>

			</StackPanel>

		</Border>

</Grid>

