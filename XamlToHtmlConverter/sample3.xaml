<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border BorderThickness="2"
            BorderBrush="DarkSlateGray"
            Padding="15"
            Width="1200"
            Height="800"
            Background="#F4F6F8">

        <DockPanel>

            <!-- TOP HEADER -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10">
                <TextBlock Text="Task Management Dashboard"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#2C3E50"/>
            </StackPanel>

            <!-- LEFT MENU -->
            <StackPanel DockPanel.Dock="Left"
                        Width="220"
                        Background="#2C3E50"
                        Margin="5">

                <TextBlock Text="MENU"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="10"/>

                <Button Content="Home" Margin="5"/>
                <Button Content="Tasks" Margin="5"/>
                <Button Content="Projects" Margin="5"/>
                <Button Content="Teams" Margin="5"/>
                <Button Content="Reports" Margin="5"/>
            </StackPanel>

            <!-- MAIN CONTENT -->
            <Grid Margin="10">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- CREATE TASK PANEL -->
                <Border Grid.Row="0"
                        Grid.ColumnSpan="2"
                        BorderBrush="#CCC"
                        BorderThickness="1"
                        Padding="10"
                        Margin="5">

                    <StackPanel Orientation="Horizontal">

                        <TextBox Width="200"
                                 Margin="5"
                                 ToolTip="Task Title"/>

                        <ComboBox Width="150" Margin="5">
                            <ComboBoxItem Content="High"/>
                            <ComboBoxItem Content="Medium"/>
                            <ComboBoxItem Content="Low"/>
                        </ComboBox>

                        <DatePicker Width="150" Margin="5"/>

                        <Button Content="Add Task"
                                Margin="10,0"/>
                    </StackPanel>

                </Border>

                <!-- TASK LIST -->
                <Border Grid.Row="1"
                        Grid.Column="0"
                        BorderBrush="#DDD"
                        BorderThickness="1"
                        Margin="5"
                        Padding="5">

                    <ListView>

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#EEE"
                                        BorderThickness="1"
                                        Margin="3"
                                        Padding="8">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="Task Name"
                                                   FontWeight="Bold"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="Due Date"/>

                                        <CheckBox Grid.Column="2"
                                                  VerticalAlignment="Center"/>
                                    </Grid>

                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>

                    </ListView>

                </Border>

                <!-- TASK DETAILS -->
                <Border Grid.Row="1"
                        Grid.Column="1"
                        BorderBrush="#DDD"
                        BorderThickness="1"
                        Margin="5"
                        Padding="10">

                    <StackPanel>

                        <TextBlock Text="Task Details"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="5"/>

                        <TextBlock Text="Title"/>
                        <TextBox Margin="5"/>

                        <TextBlock Text="Description"/>
                        <TextBox Margin="5" Height="80"
                                 TextWrapping="Wrap"/>

                        <TextBlock Text="Status"/>
                        <ComboBox Margin="5">
                            <ComboBoxItem Content="Pending"/>
                            <ComboBoxItem Content="In Progress"/>
                            <ComboBoxItem Content="Completed"/>
                        </ComboBox>

                        <Button Content="Update Task"
                                Margin="10"/>
                    </StackPanel>

                </Border>

                <!-- SUMMARY -->
                <Border Grid.Row="2"
                        Grid.ColumnSpan="2"
                        BorderBrush="#DDD"
                        BorderThickness="1"
                        Margin="5"
                        Padding="10">

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">

                        <StackPanel>
                            <TextBlock Text="Total Tasks"/>
                            <TextBlock Text="25"
                                       FontSize="20"
                                       FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Completed"/>
                            <TextBlock Text="10"
                                       FontSize="20"
                                       FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Pending"/>
                            <TextBlock Text="15"
                                       FontSize="20"
                                       FontWeight="Bold"/>
                        </StackPanel>

                    </StackPanel>

                </Border>

            </Grid>

        </DockPanel>

    </Border>

</Grid>