<Grid
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  x:Name="rootGrid"
  Width="1024"
  Height="800"
  Background="White">

  <Grid.RowDefinitions>
    <RowDefinition Height="Auto" />
    <RowDefinition Height="*" />
    <RowDefinition Height="Auto" />
  </Grid.RowDefinitions>

  <Grid.ColumnDefinitions>
    <ColumnDefinition Width="260" />
    <ColumnDefinition Width="*" />
  </Grid.ColumnDefinitions>

  <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Background="Navy" Padding="12">
    <StackPanel Orientation="Horizontal">
      <TextBlock x:Name="appTitle" Text="XamlToHtml Full Sample" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,0,16,0"/>
      <Hyperlink>Docs</Hyperlink>
      <Separator/>
      <Label Content="v2.0" Foreground="Gold" FontSize="14"/>
    </StackPanel>
  </Border>

  <Border Grid.Row="1" Grid.Column="0" Background="LightGray" BorderBrush="Gray" BorderThickness="0,0,1,0" Padding="8">
    <StackPanel>
      <TextBlock Text="Navigation" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
      <Menu>
        <MenuItem Header="File"/>
        <MenuItem Header="Edit"/>
        <MenuItem Header="View"/>
        <MenuItem Header="Help"/>
      </Menu>
      <TreeView Margin="0,8,0,0">
        <TreeViewItem Header="Components">
          <TreeViewItem Header="Layouts"/>
          <TreeViewItem Header="Controls"/>
          <TreeViewItem Header="Triggers"/>
        </TreeViewItem>
        <TreeViewItem Header="Tests"/>
      </TreeView>
    </StackPanel>
  </Border>

  <ScrollViewer Grid.Row="1" Grid.Column="1" Padding="16">
    <StackPanel>

      <GroupBox Header="Typography">
        <StackPanel Margin="0,4,0,0">
          <TextBlock Text="Normal text block"/>
          <TextBlock Text="Bold + Italic + Underlined" FontWeight="Bold" FontStyle="Italic" TextDecorations="Underline" Foreground="Teal"/>
          <TextBlock Text="Light weight, large" FontWeight="Light" FontSize="18" Opacity="0.75"/>
          <Label Content="Form Label" FontSize="13"/>
        </StackPanel>
      </GroupBox>

      <GroupBox Header="Input Controls" Margin="0,12,0,0">
        <StackPanel Margin="0,4,0,0">

          <TextBox x:Name="nameBox" Text="Hello World" MaxLength="100" Width="300" Margin="0,0,0,6">
            <TextBox.Style>
              <Style>
                <Style.Triggers>
                  <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="Blue"/>
                    <Setter Property="BorderThickness" Value="2"/>
                  </Trigger>
                </Style.Triggers>
              </Style>
            </TextBox.Style>
          </TextBox>

          <PasswordBox x:Name="passBox" Width="300" Margin="0,0,0,6"/>
          <Slider x:Name="volumeSlider" Width="200" Margin="0,0,0,6"/>
          <DatePicker x:Name="datePicker" Width="200" Margin="0,0,0,6"/>

          <CheckBox x:Name="rememberMe" Content="Remember me" Margin="0,0,0,4">
            <CheckBox.Style>
              <Style>
                <Style.Triggers>
                  <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground" Value="Green"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                  </Trigger>
                </Style.Triggers>
              </Style>
            </CheckBox.Style>
          </CheckBox>

          <StackPanel Orientation="Horizontal">
            <RadioButton Content="Option A" Margin="0,0,8,0"/>
            <RadioButton Content="Option B" Margin="0,0,8,0"/>
            <RadioButton Content="Option C"/>
          </StackPanel>

        </StackPanel>
      </GroupBox>

      <GroupBox Header="Buttons" Margin="0,12,0,0">
        <WrapPanel>
          <Button x:Name="primaryBtn" Content="Primary" Margin="0,0,8,4" Padding="12,6">
            <Button.Style>
              <Style>
                <Style.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="Blue"/>
                    <Setter Property="Foreground" Value="White"/>
                  </Trigger>
                  <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="Navy"/>
                    <Setter Property="Foreground" Value="White"/>
                  </Trigger>
                  <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="LightGray"/>
                    <Setter Property="Foreground" Value="Gray"/>
                    <Setter Property="Opacity" Value="0.5"/>
                  </Trigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
          </Button>

          <Button x:Name="warningBtn" Content="Warning" Background="Orange" Margin="0,0,8,4" Padding="12,6">
            <Button.Style>
              <Style>
                <Style.Triggers>
                  <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="Yellow"/>
                    <Setter Property="Foreground" Value="Black"/>
                  </Trigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
          </Button>

          <ToggleButton Content="Toggle" Margin="0,0,8,4" Padding="12,6"/>
          <RepeatButton Content="Hold me" Margin="0,0,8,4" Padding="12,6"/>
        </WrapPanel>
      </GroupBox>

      <!-- LIST CONTROLS with IsSelected trigger -->
      <GroupBox Header="List Controls" Margin="0,12,0,0">
        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">

          <ComboBox x:Name="statusCombo" Width="160" Margin="0,0,16,0">
            <ComboBoxItem Content="Active">
              <ComboBoxItem.Style>
                <Style>
                  <Style.Triggers>
                    <!-- IsSelected=True → [aria-selected="true"] CSS -->
                    <Trigger Property="IsSelected" Value="True">
                      <Setter Property="Background" Value="Teal"/>
                      <Setter Property="Foreground" Value="White"/>
                    </Trigger>
                  </Style.Triggers>
                </Style>
              </ComboBoxItem.Style>
            </ComboBoxItem>
            <ComboBoxItem Content="Inactive"/>
            <ComboBoxItem Content="Pending"/>
          </ComboBox>

          <ListBox x:Name="colorList" Width="160" Height="90">
            <ListBoxItem Content="Red"/>
            <ListBoxItem Content="Green"/>
            <ListBoxItem Content="Blue"/>
          </ListBox>

        </StackPanel>
      </GroupBox>

      <!-- MULTITRIGGER — both CSS-mappable → combined :hover:active selector -->
      <GroupBox Header="MultiTrigger" Margin="0,12,0,0">
        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">

          <Button x:Name="multiCssBtn" Content="Hover+Press combined CSS" Margin="0,0,16,0" Padding="12,6">
            <Button.Style>
              <Style>
                <Style.Triggers>
                  <MultiTrigger>
                    <MultiTrigger.Conditions>
                      <Condition Property="IsMouseOver" Value="True"/>
                      <Condition Property="IsPressed" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="Purple"/>
                    <Setter Property="Foreground" Value="White"/>
                  </MultiTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
          </Button>

          <!-- IsEnabled=True has no CSS mapping → falls back to data-multitrigger-* -->
          <Button x:Name="multiFallbackBtn" Content="Hover+Enabled fallback" Padding="12,6">
            <Button.Style>
              <Style>
                <Style.Triggers>
                  <MultiTrigger>
                    <MultiTrigger.Conditions>
                      <Condition Property="IsMouseOver" Value="True"/>
                      <Condition Property="IsEnabled" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="Teal"/>
                    <Setter Property="Foreground" Value="White"/>
                  </MultiTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
          </Button>

        </StackPanel>
      </GroupBox>

      <!-- DATATRIGGER — runtime binding → data-datatrigger-* + JS runtime -->
      <GroupBox Header="DataTrigger" Margin="0,12,0,0">
        <StackPanel Margin="0,4,0,0">

          <Border x:Name="statusBorder" Padding="8" BorderBrush="Gray" BorderThickness="1">
            <Border.Style>
              <Style>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsError}" Value="True">
                    <Setter Property="Background" Value="Red"/>
                    <Setter Property="BorderBrush" Value="Pink"/>
                  </DataTrigger>
                  <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                    <Setter Property="Background" Value="Green"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
            <TextBlock Text="Status message (bound)"/>
          </Border>

          <!-- MULTIDATATRIGGER — multiple runtime bindings -->
          <Border x:Name="adminPanel" Padding="8" BorderBrush="Gray" BorderThickness="1" Margin="0,8,0,0">
            <Border.Style>
              <Style>
                <Style.Triggers>
                  <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                      <Condition Binding="{Binding IsAdmin}" Value="True"/>
                      <Condition Binding="{Binding IsLoggedIn}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="Gold"/>
                    <Setter Property="Visibility" Value="Visible"/>
                  </MultiDataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
            <TextBlock Text="Admin panel (IsAdmin + IsLoggedIn)"/>
          </Border>

        </StackPanel>
      </GroupBox>

      <!-- EVENTTRIGGER — routed events → data-event-trigger-* + JS runtime -->
      <GroupBox Header="EventTrigger" Margin="0,12,0,0">
        <WrapPanel Margin="0,4,0,0">

          <!-- Button.Click -->
          <Button x:Name="clickTriggerBtn" Content="Click Trigger" Margin="0,0,8,0" Padding="12,6">
            <Button.Style>
              <Style>
                <Style.Triggers>
                  <EventTrigger RoutedEvent="Button.Click">
                    <BeginStoryboard/>
                  </EventTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
          </Button>

          <!-- Mouse.MouseEnter / MouseLeave -->
          <Border x:Name="hoverBorder" Width="120" Height="40" Background="LightGray" Margin="0,0,8,0">
            <Border.Style>
              <Style>
                <Style.Triggers>
                  <EventTrigger RoutedEvent="Mouse.MouseEnter">
                    <BeginStoryboard/>
                  </EventTrigger>
                  <EventTrigger RoutedEvent="Mouse.MouseLeave">
                    <BeginStoryboard/>
                  </EventTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
            <TextBlock Text="Hover me"/>
          </Border>

          <!-- UIElement.GotFocus / LostFocus -->
          <TextBox x:Name="focusTriggerBox" Width="160" Margin="0,0,8,0">
            <TextBox.Style>
              <Style>
                <Style.Triggers>
                  <EventTrigger RoutedEvent="UIElement.GotFocus">
                    <BeginStoryboard/>
                  </EventTrigger>
                  <EventTrigger RoutedEvent="UIElement.LostFocus">
                    <BeginStoryboard/>
                  </EventTrigger>
                </Style.Triggers>
              </Style>
            </TextBox.Style>
          </TextBox>

        </WrapPanel>
      </GroupBox>

      <!-- DATA BINDINGS -->
      <GroupBox Header="Data Bindings" Margin="0,12,0,0">
        <StackPanel Margin="0,4,0,0">
          <Button Content="Bound IsEnabled" IsEnabled="{Binding IsButtonEnabled}" Margin="0,0,0,6"/>
          <TextBlock Text="Conditionally visible" Visibility="{Binding ShowDetails}"/>
          <CheckBox Content="Accept Terms" IsChecked="{Binding HasAccepted}" Margin="0,4,0,0"/>
        </StackPanel>
      </GroupBox>

      <!-- GRID LAYOUT with spans -->
      <GroupBox Header="Grid Layout" Margin="0,12,0,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <Button Content="[0,0]" Grid.Row="0" Grid.Column="0" Margin="2"/>
          <Button Content="[0,1+2]" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="2"/>
          <Button Content="[1,0]" Grid.Row="1" Grid.Column="0" Margin="2"/>
          <Button Content="[1,1]" Grid.Row="1" Grid.Column="1" Margin="2"/>
          <Button Content="[1,2]" Grid.Row="1" Grid.Column="2" Margin="2"/>
          <Button Content="[2,0+1]" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="2"/>
          <Button Content="[2,2]" Grid.Row="2" Grid.Column="2" Margin="2"/>
        </Grid>
      </GroupBox>

      <!-- DOCKPANEL -->
      <GroupBox Header="DockPanel" Margin="0,12,0,0">
        <DockPanel Height="120">
          <Border DockPanel.Dock="Top" Background="Navy" Height="28">
            <TextBlock Text="Top" Foreground="White"/>
          </Border>
          <Border DockPanel.Dock="Bottom" Background="Teal" Height="28">
            <TextBlock Text="Bottom" Foreground="White"/>
          </Border>
          <Border DockPanel.Dock="Left" Background="Gray" Width="60">
            <TextBlock Text="Left" Foreground="White"/>
          </Border>
          <Border DockPanel.Dock="Right" Background="Gray" Width="60">
            <TextBlock Text="Right" Foreground="White"/>
          </Border>
          <Border Background="LightGray">
            <TextBlock Text="Center (fill)"/>
          </Border>
        </DockPanel>
      </GroupBox>

      <!-- CANVAS with Panel.ZIndex -->
      <GroupBox Header="Canvas + ZIndex" Margin="0,12,0,0">
        <Canvas Height="100">
          <Border Canvas.Left="10" Canvas.Top="10" Width="80" Height="50" Background="Blue" Panel.ZIndex="1">
            <TextBlock Text="Z=1" Foreground="White"/>
          </Border>
          <Border Canvas.Left="50" Canvas.Top="30" Width="80" Height="50" Background="Red" Panel.ZIndex="2">
            <TextBlock Text="Z=2" Foreground="White"/>
          </Border>
        </Canvas>
      </GroupBox>

      <!-- MEDIA, IMAGE, PROGRESS, DATAGRID -->
      <GroupBox Header="Media and Data" Margin="0,12,0,0">
        <StackPanel Margin="0,4,0,0">
          <Image Source="logo.png" Width="64" Height="64" Name="appLogo"/>
          <ProgressBar Value="65" Width="200" Height="18" Margin="0,8,0,0"/>
          <MediaElement Width="320" Height="180" Margin="0,8,0,0"/>
          <DataGrid Margin="0,8,0,0" Height="100"/>
        </StackPanel>
      </GroupBox>

      <!-- EXPANDER, RICHTEXTBOX, FRAME, CONTENTCONTROL -->
      <GroupBox Header="Advanced Controls" Margin="0,12,0,0">
        <StackPanel Margin="0,4,0,0">
          <Expander Header="Click to expand">
            <TextBlock Text="Hidden content revealed." Margin="8"/>
          </Expander>
          <RichTextBox Height="60" Margin="0,8,0,0"/>
          <Frame Width="300" Height="80" Margin="0,8,0,0"/>
          <ContentControl Margin="0,8,0,0">
            <TextBlock Text="ContentControl wraps anything."/>
          </ContentControl>
        </StackPanel>
      </GroupBox>

    </StackPanel>
  </ScrollViewer>

  <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Background="LightGray" BorderBrush="Gray" BorderThickness="0,1,0,0" Padding="12,6">
    <StackPanel Orientation="Horizontal">
      <TextBlock Text="© 2026 Medtronic, plc." FontSize="12" Opacity="0.7"/>
      <Separator/>
      <TextBlock Text="XamlToHtmlConverter Sample" FontSize="12" Opacity="0.7"/>
    </StackPanel>
  </Border>

</Grid>